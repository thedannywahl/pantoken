{
  "name": "@pantoken/postcss",
  "version": "0.1.1",
  "description": "PostCSS plugin for pantoken: expands an @pantoken at-rule into the token stylesheet.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/pantoken.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/css": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "postcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "postcss": ">=8"
  },
  "pantoken": {
    "key": "postcss",
    "kind": "subpath"
  }
}
