{
  "name": "@pantoken/angular",
  "version": "0.0.0",
  "description": "Angular helpers for pantoken: register the web components and read tokens.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./components.css": "./dist/components.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp run generate && vp pack",
    "dev": "vp run generate && vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/web-components": "workspace:*"
  },
  "devDependencies": {
    "@pantoken/components": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@angular/core": ">=16"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    }
  },
  "pantoken": {
    "key": "angular",
    "kind": "subpath"
  }
}
