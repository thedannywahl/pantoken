{
  "name": "@pantoken/pendo",
  "version": "0.1.0",
  "description": "Instructure-styled global CSS for Pendo guides, built on pantoken tokens (ported from @instructure/pendo-global-css).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/pantoken.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./global.css": "./dist/global.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "embed": "node scripts/embed.ts",
    "generate": "node scripts/generate.ts",
    "dev": "vp run embed && vp run generate && vp pack --watch",
    "test": "vp run embed && vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/components": "workspace:*",
    "@pantoken/css": "workspace:*",
    "@pantoken/model": "workspace:*",
    "@pantoken/plugin-prune-custom-props": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "postcss": "catalog:"
  },
  "devDependencies": {
    "@pantoken/utils": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "pendo",
    "kind": "subpath"
  }
}
