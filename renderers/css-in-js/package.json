{
  "name": "@pantoken/css-in-js",
  "version": "0.0.0",
  "description": "Instructure theme object for runtime CSS-in-JS (Emotion, styled-components, Stitches): camelCased tokens, var()-backed.",
  "license": "MIT",
  "files": [
    "dist",
    "generated/components.css"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./components.css": "./generated/components.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp pack && vp run generate",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@pantoken/components": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "cssInJs",
    "kind": "namespace"
  }
}
