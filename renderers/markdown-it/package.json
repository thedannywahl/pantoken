{
  "name": "@pantoken/markdown-it",
  "version": "0.0.0",
  "description": "markdown-it plugin: render :icon: codes as inline SVG and color values as swatches, using the pantoken icon set.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/icons": "workspace:*",
    "@pantoken/model": "workspace:*"
  },
  "devDependencies": {
    "@pantoken/plugin-simple-icons": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/node": "catalog:",
    "markdown-it": "catalog:",
    "simple-icons": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "markdown-it": ">=14"
  },
  "pantoken": {
    "key": "markdown-it",
    "kind": "subpath"
  }
}
