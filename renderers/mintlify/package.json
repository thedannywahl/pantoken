{
  "name": "@pantoken/mintlify",
  "version": "0.1.0",
  "description": "Theme a Mintlify docs site with Instructure tokens: the docs.json colors + background, resolved to concrete hex per mode.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/pantoken.git"
  },
  "files": [
    "dist",
    "generated/docs.json"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./docs.json": "./generated/docs.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "mintlify",
    "kind": "namespace"
  }
}
