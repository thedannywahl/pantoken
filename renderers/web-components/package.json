{
  "name": "@pantoken/web-components",
  "version": "0.1.0",
  "description": "Framework-agnostic custom elements for Instructure UI: <instui-icon> plus token-styled primitives.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./components.css": "./dist/components.css",
    "./*.css": "./dist/*.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "node scripts/generate.ts && node scripts/build-entries.ts && vp pack",
    "dev": "node scripts/generate.ts && node scripts/build-entries.ts && vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/components": "workspace:*",
    "@pantoken/icons": "workspace:*",
    "@pantoken/model": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "webComponents",
    "kind": "namespace"
  }
}
