{
  "$schema": "https://cssdoc.dev/cssdoc.schema.json",
  "modifierConvention": "rscss",
  "inlineComments": "ignore",
  "render": {
    "sectionOrder": [
      "accessibility",
      "usage",
      "demo",
      "examples",
      "structure",
      "slots",
      "modifiers",
      "parts",
      "shadowParts",
      "states",
      "cssProperties",
      "functions",
      "animations",
      "layers",
      "conditions",
      "tokensConsumed",
      "compat",
      "related",
      "see",
    ],
    "headingPrefix": "CSS:",
    "structureView": "both",
  },
}
