{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "../packages/*/src/**/*.ts",
    "../formats/*/src/**/*.ts",
    "../platforms/*/src/**/*.ts",
    "../renderers/*/src/**/*.ts",
    "../renderers/*/src/**/*.tsx",
    "../bundlers/*/src/**/*.ts",
    "../design/*/src/**/*.ts",
    "../ai/*/src/**/*.ts",
    "../plugins/pantoken/*/src/**/*.ts",
    "../plugins/postcss/*/src/**/*.ts",
    "../tools/aggregate/src/**/*.ts",
    "../tools/demo/src/**/*.ts",
    "../plugins/typedoc/demo/src/**/*.ts",
    "../plugins/vite/workspace-orchestrator/src/**/*.ts"
  ]
}
