{
  "name": "@pantoken/docs",
  "version": "0.0.0",
  "private": true,
  "description": "The pantoken documentation site: hand-written guides (VitePress) plus an auto-generated API reference (TypeDoc), themed with pantoken's own tokens.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "docs:api": "node scripts/build-api-locales.ts",
    "docs:api:en": "typedoc --options typedoc.json --out api",
    "docs:api:css": "node scripts/build-css-api.ts",
    "docs:api:locales": "node scripts/build-api-locales.ts",
    "docs:api:locales:claude": "DOCS_TRANSLATION_ADAPTER=claude-code node scripts/build-api-locales.ts",
    "docs:guides:locales": "node scripts/translate-guides.ts",
    "docs:guides:locales:claude": "DOCS_TRANSLATION_ADAPTER=claude-code node scripts/translate-guides.ts",
    "docs:check:locales": "node scripts/check-locale-parity.ts",
    "docs:assets": "node scripts/logo.ts && node scripts/site-themes.ts && node scripts/demos.ts",
    "docs:dev": "vp run docs:assets && vp run docs:api:en && vp run @pantoken/components#generate && vp run docs:api:css && vitepress dev",
    "docs:dev:all": "vp run docs:assets && vp run docs:api:locales && vp run docs:check:locales && vitepress dev",
    "docs:build": "vp run docs:assets && vp run docs:api:locales && vp run docs:check:locales && vitepress build",
    "docs:build:claude": "vp run docs:assets && vp run docs:api:locales:claude && vp run docs:check:locales && vitepress build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "@cssdoc/config": "catalog:",
    "@cssdoc/core": "catalog:",
    "@cssdoc/typedoc": "catalog:",
    "@pantoken/components": "workspace:*",
    "@pantoken/css": "workspace:*",
    "@pantoken/demo": "workspace:*",
    "@pantoken/plugin-logos": "workspace:*",
    "@pantoken/plugin-stacking": "workspace:*",
    "@pantoken/plugin-transition": "workspace:*",
    "@pantoken/plugin-visual-debug": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/typedoc-plugin-demo": "workspace:*",
    "@pantoken/utils": "workspace:*",
    "@pantoken/vite-workspace-orchestrator": "workspace:*",
    "@pantoken/vitepress": "workspace:*",
    "@pantoken/web-components": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/node": "catalog:",
    "markdown-it": "catalog:",
    "mermaid": "catalog:",
    "oxc-minify": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typedoc-vitepress-theme": "catalog:",
    "typescript": "catalog:",
    "vitepress": "catalog:",
    "vitepress-plugin-llms": "catalog:",
    "vue": "catalog:"
  }
}
