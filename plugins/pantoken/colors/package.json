{
  "name": "@pantoken/plugin-colors",
  "version": "0.0.0",
  "description": "pantoken plugin: CSS-only color math (alpha, darken, lighten, overlayColors) that mirrors the InstUI ui-color-utils, built on color-mix() and relative color syntax.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "colors",
    "kind": "namespace"
  }
}
