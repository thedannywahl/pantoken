{
  "name": "@pantoken/plugin-logos",
  "version": "0.0.0",
  "description": "pantoken plugin: Instructure product logos (Canvas, Mastery, Parchment, and more) as SVGs, data URIs, and --instui-logo-* image tokens.",
  "license": "MIT",
  "files": [
    "dist",
    "generated/logos.css",
    "assets/logos"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./logos.css": "./generated/logos.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp run generate && vp pack",
    "dev": "vp pack --watch",
    "test": "vp run generate && vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/plugin-kit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "logos",
    "kind": "namespace"
  }
}
