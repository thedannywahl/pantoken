{
  "name": "@pantoken/plugin-prune-custom-props",
  "version": "0.0.0",
  "description": "pantoken plugin: a PostCSS plugin that tree-shakes unused --instui-* custom properties from a composed stylesheet.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "postcss": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "pruneCustomProps",
    "kind": "namespace"
  }
}
