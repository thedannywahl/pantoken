{
  "name": "pantoken",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp run -r build && vp check && vp run -r test && pnpm run validate:generated:only && pnpm run lint:markdown",
    "generate": "vp run -r build",
    "validate:generated": "pnpm run generate && pnpm run validate:generated:only",
    "validate:generated:only": "vp run @pantoken/validate-generated#validate",
    "docs:dev": "vp run @pantoken/docs#docs:dev",
    "docs:build": "vp run @pantoken/docs#docs:build",
    "docs:preview": "vp run @pantoken/docs#docs:preview",
    "docs:api": "vp run @pantoken/docs#docs:api",
    "lint:markdown": "vp exec markdownlint-cli2 \"**/*.md\"",
    "check:publish": "pnpm -r --filter \"./packages/**\" --filter \"./formats/**\" --filter \"./platforms/**\" --filter \"./renderers/**\" --filter \"./bundlers/**\" --filter \"./design/**\" --filter \"./ai/**\" --filter \"./plugins/**\" --filter \"./tools/**\" exec publint"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "markdownlint-cli2": "catalog:",
    "publint": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
