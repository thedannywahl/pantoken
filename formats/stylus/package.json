{
  "name": "@pantoken/stylus",
  "version": "0.0.0",
  "description": "Instructure design tokens as Stylus variables (resolved, single-mode) from the pantoken IR.",
  "license": "MIT",
  "files": [
    "dist",
    "generated/tokens.styl"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./tokens.styl": "./generated/tokens.styl",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp pack && pnpm run generate",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "stylus",
    "kind": "namespace"
  }
}
