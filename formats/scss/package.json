{
  "name": "@pantoken/scss",
  "version": "0.0.0",
  "description": "Instructure design tokens as SCSS variables (resolved, single-mode) from the pantoken IR.",
  "license": "MIT",
  "files": [
    "dist",
    "generated/tokens.scss"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./tokens.scss": "./generated/tokens.scss",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp pack && vp run generate",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "scss",
    "kind": "namespace"
  }
}
