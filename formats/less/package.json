{
  "name": "@pantoken/less",
  "version": "0.1.1",
  "description": "Instructure design tokens as Less variables (resolved, single-mode) from the pantoken IR.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/pantoken.git"
  },
  "files": [
    "dist",
    "generated/tokens.less"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./tokens.less": "./generated/tokens.less",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "less",
    "kind": "namespace"
  }
