{
  "name": "@pantoken/dtcg",
  "version": "0.1.0",
  "description": "W3C Design Tokens (DTCG) JSON export of the Instructure tokens — an interchange format for Style Dictionary, Figma, and other tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thedannywahl/pantoken.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.ts",
    "build": "vp run generate && vp pack",
    "dev": "vp pack --watch",
    "test": "vp run generate && vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/model": "workspace:*",
    "@pantoken/utils": "workspace:*"
  },
  "devDependencies": {
    "@pantoken/tokens": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pantoken": {
    "key": "dtcg",
    "kind": "namespace"
  }
}
