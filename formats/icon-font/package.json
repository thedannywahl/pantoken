{
  "name": "@pantoken/icon-font",
  "version": "0.0.0",
  "description": "Build an installable Instructure icon font (WOFF2 + TTF) with CSS and codepoints — stroke glyphs outlined to fills.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@pantoken/core": "workspace:*",
    "@pantoken/model": "workspace:*",
    "@pantoken/tokens": "workspace:*",
    "clipper-lib": "catalog:",
    "points-on-path": "catalog:",
    "svg2ttf": "catalog:",
    "svgicons2svgfont": "catalog:",
    "ttf2woff2": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2",
    "vite-plus": "catalog:"
  }
}
